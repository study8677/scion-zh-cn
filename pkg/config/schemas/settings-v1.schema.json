{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scion.dev/schemas/settings/v1.json",
  "title": "Scion Settings",
  "description": "Configuration for the Scion agent orchestration platform (v1).",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema URI for IDE support."
    },
    "schema_version": {
      "type": "string",
      "const": "1",
      "description": "Settings schema version. Required for versioned settings.",
      "x-since": "1"
    },
    "active_profile": {
      "type": "string",
      "default": "local",
      "description": "Name of the active profile.",
      "x-env-var": "SCION_ACTIVE_PROFILE",
      "x-scope": "any",
      "x-since": "1"
    },
    "default_template": {
      "type": "string",
      "description": "Default template for new agents. Preserved for backward compatibility; prefer setting this per-profile.",
      "x-env-var": "SCION_DEFAULT_TEMPLATE",
      "x-scope": "any",
      "x-since": "1"
    },
    "default_harness_config": {
      "type": "string",
      "description": "Default harness-config name for new agents. Used as last resort in the resolution chain.",
      "x-env-var": "SCION_DEFAULT_HARNESS_CONFIG",
      "x-scope": "any",
      "x-since": "1"
    },
    "image_registry": {
      "type": "string",
      "description": "Container image registry prefix. When set, replaces the registry portion of any scion-* harness-config image at resolution time.",
      "x-env-var": "SCION_IMAGE_REGISTRY",
      "x-scope": "any",
      "x-since": "1"
    },
    "server": {
      "type": "object",
      "description": "Server/broker process configuration. Global-only.",
      "x-scope": "global",
      "x-since": "1",
      "properties": {
        "env": {
          "type": "string",
          "description": "Deployment environment label (e.g., dev, staging, prod).",
          "x-env-var": "SCION_SERVER_ENV",
          "x-since": "1"
        },
        "hub": { "$ref": "#/$defs/serverHub" },
        "broker": { "$ref": "#/$defs/serverBroker" },
        "database": { "$ref": "#/$defs/serverDatabase" },
        "auth": { "$ref": "#/$defs/serverAuth" },
        "oauth": { "$ref": "#/$defs/serverOAuth" },
        "storage": { "$ref": "#/$defs/serverStorage" },
        "secrets": { "$ref": "#/$defs/serverSecrets" },
        "log_level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info",
          "x-env-var": "SCION_SERVER_LOG_LEVEL",
          "x-since": "1"
        },
        "log_format": {
          "type": "string",
          "enum": ["text", "json"],
          "default": "text",
          "x-env-var": "SCION_SERVER_LOG_FORMAT",
          "x-since": "1"
        }
      },
      "additionalProperties": false
    },
    "hub": {
      "type": "object",
      "description": "Hub client connection settings. Auth uses server.auth.dev_token (dev mode) or OAuth (production).",
      "x-scope": "any",
      "x-since": "1",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Hub integration.",
          "x-env-var": "SCION_HUB_ENABLED",
          "x-since": "1"
        },
        "endpoint": {
          "type": "string",
          "format": "uri",
          "description": "Hub API endpoint URL to connect to as a client.",
          "x-env-var": "SCION_HUB_ENDPOINT",
          "x-since": "1"
        },
        "project_id": {
          "type": "string",
          "description": "Project identifier when registered with the Hub. Formerly known as 'grove_id', which is still accepted for backward compatibility.",
          "x-env-var": "SCION_HUB_PROJECT_ID",
          "x-since": "1"
        },
        "grove_id": {
          "type": "string",
          "description": "Deprecated: Use 'project_id' instead.",
          "x-env-var": "SCION_HUB_GROVE_ID",
          "x-since": "1"
        },
        "local_only": {
          "type": "boolean",
          "description": "Operate in local-only mode even when Hub is configured.",
          "x-env-var": "SCION_HUB_LOCAL_ONLY",
          "x-since": "1"
        }
      },
      "additionalProperties": false
    },
    "cli": {
      "type": "object",
      "description": "CLI behavior settings.",
      "x-scope": "any",
      "x-since": "1",
      "properties": {
        "autohelp": {
          "type": "boolean",
          "default": true,
          "description": "Print usage help on errors.",
          "x-env-var": "SCION_CLI_AUTOHELP",
          "x-since": "1"
        },
        "interactive_disabled": {
          "type": "boolean",
          "default": false,
          "description": "Disable interactive prompts (useful for CI/scripts).",
          "x-env-var": "SCION_CLI_INTERACTIVE_DISABLED",
          "x-since": "1"
        }
      },
      "additionalProperties": false
    },
    "telemetry": {
      "$ref": "#/$defs/telemetryConfig",
      "description": "Telemetry and observability settings. Merged across global, grove, template, and agent scopes (last write wins).",
      "x-scope": "any",
      "x-since": "1"
    },
    "runtimes": {
      "type": "object",
      "description": "Named container runtime definitions. Map keys are arbitrary labels; the 'type' field determines the runtime type.",
      "x-scope": "any",
      "x-since": "1",
      "additionalProperties": {
        "$ref": "#/$defs/runtimeConfig"
      }
    },
    "harness_configs": {
      "type": "object",
      "description": "Named harness configurations. Multiple configs may share a harness type.",
      "x-scope": "any",
      "x-since": "1",
      "additionalProperties": {
        "$ref": "#/$defs/harnessConfig"
      }
    },
    "profiles": {
      "type": "object",
      "description": "Named environment profiles.",
      "x-scope": "any",
      "x-since": "1",
      "additionalProperties": {
        "$ref": "#/$defs/profileConfig"
      }
    },
    "default_max_turns": {
      "type": "integer",
      "minimum": 1,
      "description": "Default max turns for new agents. Applied when no explicit value is set.",
      "x-scope": "any",
      "x-since": "1"
    },
    "default_max_model_calls": {
      "type": "integer",
      "minimum": 1,
      "description": "Default max model calls for new agents.",
      "x-scope": "any",
      "x-since": "1"
    },
    "default_max_duration": {
      "type": "string",
      "description": "Default max duration for new agents (Go duration, e.g. '2h', '30m').",
      "x-scope": "any",
      "x-since": "1"
    },
    "default_resources": {
      "$ref": "#/$defs/resourceSpec",
      "description": "Default resource requests/limits for new agents.",
      "x-scope": "any",
      "x-since": "1"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "runtimeConfig": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["docker", "podman", "container", "kubernetes"],
          "description": "Runtime type. Defaults to the runtime entry name if omitted."
        },
        "host": { "type": "string" },
        "context": { "type": "string" },
        "namespace": { "type": "string" },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "sync": { "type": "string" },
        "gke": {
          "type": "boolean",
          "default": false,
          "description": "Enable GKE-specific features (e.g., Workload Identity)."
        }
      },
      "additionalProperties": false
    },
    "harnessConfig": {
      "type": "object",
      "required": ["harness"],
      "properties": {
        "harness": {
          "type": "string",
          "minLength": 1,
          "description": "The harness type this config applies to."
        },
        "image": {
          "type": "string",
          "description": "Container image URI."
        },
        "user": {
          "type": "string",
          "description": "Unix user inside the container."
        },
        "model": {
          "type": "string",
          "description": "LLM model identifier."
        },
        "task_flag": {
          "type": "string",
          "description": "CLI flag name for passing the task to the harness (e.g., '--input'). When set, the task is delivered as a flag value instead of a positional argument."
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Additional harness CLI arguments."
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "volumes": {
          "type": "array",
          "items": { "$ref": "#/$defs/volumeMount" }
        },
        "auth_selected_type": {
          "type": "string",
          "enum": ["api-key", "oauth-token", "auth-file", "vertex-ai"],
          "description": "Authentication mechanism to use (e.g., api-key, oauth-token, vertex-ai, auth-file)."
        },
        "secrets": {
          "type": "array",
          "items": { "$ref": "#/$defs/requiredSecret" },
          "description": "Required secrets for this harness configuration."
        },
        "model_aliases": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Maps abstract model size aliases (e.g. small, medium, large) to concrete harness-specific model names. Templates use the alias; it is resolved at provision time."
        },
        "provisioner": {
          "$ref": "#/$defs/harnessProvisioner",
          "description": "Provisioning implementation metadata. Presence of a script file alone does not activate container-script behavior."
        },
        "config_dir": {
          "type": "string",
          "description": "Default harness-native config directory relative to the agent home."
        },
        "skills_dir": {
          "type": "string",
          "description": "Harness-native skills directory relative to the agent home."
        },
        "interrupt_key": {
          "type": "string",
          "description": "Key sequence used to interrupt the harness process."
        },
        "instructions_file": {
          "type": "string",
          "description": "Harness-native file that receives agent instructions."
        },
        "system_prompt_file": {
          "type": "string",
          "description": "Harness-native file that receives system prompt content when supported."
        },
        "system_prompt_mode": {
          "type": "string",
          "enum": ["native", "prepend_to_instructions", "none"],
          "description": "How the harness consumes a system prompt."
        },
        "command": {
          "$ref": "#/$defs/harnessCommand",
          "description": "Declarative command construction metadata."
        },
        "env_template": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Declarative environment defaults with template expressions."
        },
        "capabilities": {
          "$ref": "#/$defs/harnessCapabilities",
          "description": "Advanced capability advertisement for this harness config."
        },
        "auth": {
          "$ref": "#/$defs/harnessAuthMetadata",
          "description": "Declarative auth preflight metadata for broker and hosted dispatch."
        },
        "mcp": {
          "$ref": "#/$defs/harnessMCPMapping",
          "description": "Declarative mapping for translating universal mcp_servers into the harness's native MCP config (used by scion_harness.apply_mcp_servers_simple). Harnesses with bespoke MCP formats (e.g. OpenCode) leave this empty and translate themselves in provision.py."
        },
        "dialect": {
          "type": "object",
          "description": "Optional hook dialect metadata.",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "harnessMCPMapping": {
      "type": "object",
      "properties": {
        "global_config_file": {
          "type": "string",
          "description": "Agent-home-relative path to the file holding global-scope MCP entries (e.g. '.claude.json')."
        },
        "global_config_path": {
          "type": "string",
          "description": "Dotted JSON path inside global_config_file where the per-name MCP map lives (e.g. 'mcpServers')."
        },
        "project_config_file": {
          "type": "string",
          "description": "Agent-home-relative path for project-scope MCP entries; may be the same file as global_config_file."
        },
        "project_config_path": {
          "type": "string",
          "description": "Dotted JSON path for project-scope MCP entries; may include '{workspace}' which is substituted with the agent_workspace path."
        },
        "transport_field": {
          "type": "string",
          "description": "Field name in the native server object that holds the transport identifier (e.g. 'type')."
        },
        "transport_map": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Maps universal transport values (stdio/sse/streamable-http) to the native value."
        }
      },
      "additionalProperties": false
    },
    "harnessProvisioner": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["builtin", "container-script", "plugin", "generic"]
        },
        "interface_version": {
          "type": "integer",
          "minimum": 1
        },
        "command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timeout": {
          "type": "string"
        },
        "lifecycle_events": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_image_tools": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "harnessCommand": {
      "type": "object",
      "properties": {
        "base": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resume_flag": { "type": "string" },
        "task_flag": { "type": ["string", "null"] },
        "task_position": {
          "type": "string",
          "enum": ["after_base_args", "before_base_args", "positional"]
        },
        "system_prompt_flag": { "type": "string" }
      },
      "additionalProperties": false
    },
    "capabilityField": {
      "type": "object",
      "required": ["support"],
      "properties": {
        "support": {
          "type": "string",
          "enum": ["yes", "no", "partial"]
        },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "harnessCapabilities": {
      "type": "object",
      "properties": {
        "harness": { "type": "string" },
        "limits": {
          "type": "object",
          "properties": {
            "max_turns": { "$ref": "#/$defs/capabilityField" },
            "max_model_calls": { "$ref": "#/$defs/capabilityField" },
            "max_duration": { "$ref": "#/$defs/capabilityField" }
          },
          "additionalProperties": false
        },
        "telemetry": {
          "type": "object",
          "properties": {
            "enabled": { "$ref": "#/$defs/capabilityField" },
            "native_emitter": { "$ref": "#/$defs/capabilityField" }
          },
          "additionalProperties": false
        },
        "prompts": {
          "type": "object",
          "properties": {
            "system_prompt": { "$ref": "#/$defs/capabilityField" },
            "agent_instructions": { "$ref": "#/$defs/capabilityField" }
          },
          "additionalProperties": false
        },
        "auth": {
          "type": "object",
          "properties": {
            "api_key": { "$ref": "#/$defs/capabilityField" },
            "auth_file": { "$ref": "#/$defs/capabilityField" },
            "oauth_token": { "$ref": "#/$defs/capabilityField" },
            "vertex_ai": { "$ref": "#/$defs/capabilityField" }
          },
          "additionalProperties": false
        },
        "mcp": {
          "type": "object",
          "properties": {
            "stdio": { "$ref": "#/$defs/capabilityField" },
            "sse": { "$ref": "#/$defs/capabilityField" },
            "streamable_http": { "$ref": "#/$defs/capabilityField" },
            "project_scope": { "$ref": "#/$defs/capabilityField" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "harnessAuthMetadata": {
      "type": "object",
      "properties": {
        "default_type": {
          "type": "string",
          "enum": ["api-key", "oauth-token", "auth-file", "vertex-ai"]
        },
        "types": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/harnessAuthTypeMetadata" }
        },
        "autodetect": { "$ref": "#/$defs/harnessAuthAutodetect" }
      },
      "additionalProperties": false
    },
    "harnessAuthTypeMetadata": {
      "type": "object",
      "properties": {
        "required_env": {
          "type": "array",
          "items": { "$ref": "#/$defs/harnessAuthEnvRequirement" }
        },
        "required_files": {
          "type": "array",
          "items": { "$ref": "#/$defs/harnessAuthFileRequirement" }
        }
      },
      "additionalProperties": false
    },
    "harnessAuthEnvRequirement": {
      "type": "object",
      "properties": {
        "any_of": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "harnessAuthFileRequirement": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "target_suffix": { "type": "string" },
        "alternative_env_keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "skipped_when_gcp_service_account_assigned": { "type": "boolean" },
        "required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "harnessAuthAutodetect": {
      "type": "object",
      "properties": {
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["api-key", "oauth-token", "auth-file", "vertex-ai"]
          }
        },
        "files": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["api-key", "oauth-token", "auth-file", "vertex-ai"]
          }
        }
      },
      "additionalProperties": false
    },
    "profileConfig": {
      "type": "object",
      "required": ["runtime"],
      "properties": {
        "runtime": {
          "type": "string",
          "description": "Name of the runtime (key in runtimes map) to use."
        },
        "default_template": {
          "type": "string",
          "description": "Default template for agents created under this profile."
        },
        "default_harness_config": {
          "type": "string",
          "description": "Default harness config name for agents under this profile."
        },
        "image_registry": {
          "type": "string",
          "description": "Container image registry prefix for this profile. Overrides the top-level image_registry."
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "volumes": {
          "type": "array",
          "items": { "$ref": "#/$defs/volumeMount" }
        },
        "resources": { "$ref": "#/$defs/resourceSpec" },
        "harness_overrides": {
          "type": "object",
          "description": "Per-harness-config overrides applied when using this profile. Keys are harness-config names.",
          "additionalProperties": { "$ref": "#/$defs/harnessOverride" }
        },
        "secrets": {
          "type": "array",
          "items": { "$ref": "#/$defs/requiredSecret" },
          "description": "Required secrets for agents created under this profile."
        }
      },
      "additionalProperties": false
    },
    "harnessOverride": {
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "user": { "type": "string" },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "volumes": {
          "type": "array",
          "items": { "$ref": "#/$defs/volumeMount" }
        },
        "resources": { "$ref": "#/$defs/resourceSpec" },
        "auth_selected_type": {
          "type": "string",
          "enum": ["api-key", "oauth-token", "auth-file", "vertex-ai"]
        }
      },
      "additionalProperties": false
    },
    "volumeMount": {
      "type": "object",
      "required": ["target"],
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "read_only": { "type": "boolean", "default": false },
        "type": { "type": "string", "enum": ["local", "gcs"], "default": "local" },
        "bucket": { "type": "string" },
        "prefix": { "type": "string" },
        "mode": { "type": "string" }
      }
    },
    "resourceSpec": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "disk": { "type": "string" }
      }
    },
    "serverHub": {
      "type": "object",
      "description": "Hub API server settings (for running scion-server).",
      "properties": {
        "port": { "type": "integer", "default": 9810, "x-env-var": "SCION_SERVER_HUB_PORT" },
        "host": { "type": "string", "default": "0.0.0.0", "x-env-var": "SCION_SERVER_HUB_HOST" },
        "hub_id": {
          "type": "string",
          "description": "Stable hub instance identifier used for hub-scoped secret namespacing.",
          "x-env-var": "SCION_SERVER_HUB_HUBID"
        },
        "public_url": {
          "type": "string",
          "format": "uri",
          "description": "Public-facing URL for this Hub server. Passed to agents for status callbacks.",
          "x-env-var": "SCION_SERVER_HUB_ENDPOINT",
          "x-env-var-alias": "SCION_SERVER_HUB_PUBLIC_URL"
        },
        "read_timeout": { "type": "string", "default": "30s", "x-env-var": "SCION_SERVER_HUB_READTIMEOUT" },
        "write_timeout": { "type": "string", "default": "60s", "x-env-var": "SCION_SERVER_HUB_WRITETIMEOUT" },
        "cors": { "$ref": "#/$defs/corsConfig" },
        "admin_emails": {
          "type": "array",
          "items": { "type": "string", "format": "email" },
          "description": "Email addresses to auto-promote to admin role.",
          "x-env-var": "SCION_SERVER_HUB_ADMINEMAIL"
        },
        "soft_delete_retention": {
          "type": "string",
          "description": "How long soft-deleted agents are retained before permanent cleanup (e.g., '72h').",
          "x-env-var": "SCION_SERVER_HUB_SOFT_DELETE_RETENTION",
          "x-since": "1"
        },
        "soft_delete_retain_files": {
          "type": "boolean",
          "description": "Preserve workspace files during soft-delete period.",
          "x-env-var": "SCION_SERVER_HUB_SOFT_DELETE_RETAIN_FILES",
          "x-since": "1"
        }
      }
    },
    "serverBroker": {
      "type": "object",
      "description": "Broker API server and identity settings.",
      "properties": {
        "enabled": { "type": "boolean", "default": false, "x-env-var": "SCION_SERVER_BROKER_ENABLED" },
        "port": { "type": "integer", "default": 9800, "x-env-var": "SCION_SERVER_BROKER_PORT" },
        "host": { "type": "string", "default": "0.0.0.0", "x-env-var": "SCION_SERVER_BROKER_HOST" },
        "read_timeout": { "type": "string", "default": "30s", "x-env-var": "SCION_SERVER_BROKER_READTIMEOUT" },
        "write_timeout": { "type": "string", "default": "120s", "x-env-var": "SCION_SERVER_BROKER_WRITETIMEOUT" },
        "hub_endpoint": {
          "type": "string",
          "format": "uri",
          "description": "Hub API endpoint for this broker to report status to.",
          "x-env-var": "SCION_SERVER_BROKER_HUBENDPOINT"
        },
        "container_hub_endpoint": {
          "type": "string",
          "format": "uri",
          "description": "Overrides hub_endpoint when injecting the Hub URL into agent containers. Use when containers cannot reach the Hub at the broker's address (e.g. http://host.containers.internal:8080 for local development).",
          "x-env-var": "SCION_SERVER_BROKER_CONTAINERHUBENDPOINT"
        },
        "broker_id": {
          "type": "string",
          "description": "Unique broker identifier (UUID). Auto-generated if empty.",
          "x-env-var": "SCION_SERVER_BROKER_BROKERID"
        },
        "auto_provide": {
          "type": "boolean",
          "description": "Automatically add as provider for new groves.",
          "x-env-var": "SCION_SERVER_BROKER_AUTOPROVIDE"
        },
        "broker_name": {
          "type": "string",
          "description": "Human-readable broker name.",
          "x-env-var": "SCION_SERVER_BROKER_BROKERNAME"
        },
        "broker_nickname": {
          "type": "string",
          "description": "Human-readable display name for the broker. Defaults to hostname.",
          "x-env-var": "SCION_SERVER_BROKER_BROKERNICKNAME"
        },
        "broker_token": {
          "type": "string",
          "description": "Token received when registering this broker with the Hub.",
          "x-sensitive": true,
          "x-env-var": "SCION_SERVER_BROKER_BROKERTOKEN"
        },
        "allow_container_script_harnesses": {
          "type": "boolean",
          "default": false,
          "description": "Allow agents whose harness-config declares provisioner.type: container-script. Container-script provisioners execute scripts inside the agent container with access to projected secrets, so brokers must opt in explicitly.",
          "x-env-var": "SCION_SERVER_BROKER_ALLOWCONTAINERSCRIPTHARNESSES"
        },
        "cors": { "$ref": "#/$defs/corsConfig" }
      }
    },
    "corsConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "allowed_origins": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["*"]
        },
        "allowed_methods": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowed_headers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "max_age": { "type": "integer", "default": 3600 }
      }
    },
    "serverDatabase": {
      "type": "object",
      "properties": {
        "driver": { "type": "string", "enum": ["sqlite", "postgres"], "default": "sqlite", "x-env-var": "SCION_SERVER_DATABASE_DRIVER" },
        "url": { "type": "string", "x-env-var": "SCION_SERVER_DATABASE_URL" }
      }
    },
    "serverAuth": {
      "type": "object",
      "description": "Auth settings. dev_token/dev_token_file are used by both the server and the hub client in dev mode.",
      "properties": {
        "dev_mode": { "type": "boolean", "default": false, "x-env-var": "SCION_SERVER_AUTH_DEVMODE" },
        "dev_token": {
          "type": "string",
          "description": "Dev auth token for dev-mode authentication.",
          "x-sensitive": true,
          "x-env-var": "SCION_SERVER_AUTH_DEVTOKEN"
        },
        "dev_token_file": { "type": "string", "x-env-var": "SCION_SERVER_AUTH_DEVTOKENFILE" },
        "authorized_domains": {
          "type": "array",
          "items": { "type": "string" },
          "x-env-var": "SCION_SERVER_AUTH_AUTHORIZEDDOMAINS"
        }
      }
    },
    "serverOAuth": {
      "type": "object",
      "description": "OAuth provider configurations for web, CLI, and device flows.",
      "properties": {
        "web": { "$ref": "#/$defs/oauthClientConfig" },
        "cli": { "$ref": "#/$defs/oauthClientConfig" },
        "device": { "$ref": "#/$defs/oauthClientConfig" }
      }
    },
    "oauthClientConfig": {
      "type": "object",
      "properties": {
        "google": { "$ref": "#/$defs/oauthProviderConfig" },
        "github": { "$ref": "#/$defs/oauthProviderConfig" }
      }
    },
    "oauthProviderConfig": {
      "type": "object",
      "properties": {
        "client_id": { "type": "string" },
        "client_secret": { "type": "string", "x-sensitive": true }
      }
    },
    "serverStorage": {
      "type": "object",
      "description": "Unified storage configuration.",
      "properties": {
        "provider": { "type": "string", "enum": ["local", "gcs"], "default": "local", "x-env-var": "SCION_SERVER_STORAGE_PROVIDER" },
        "bucket": { "type": "string", "description": "GCS bucket name.", "x-env-var": "SCION_SERVER_STORAGE_BUCKET" },
        "local_path": { "type": "string", "x-env-var": "SCION_SERVER_STORAGE_LOCALPATH" }
      }
    },
    "serverSecrets": {
      "type": "object",
      "properties": {
        "backend": { "type": "string", "enum": ["local", "gcpsm"], "default": "local", "x-env-var": "SCION_SERVER_SECRETS_BACKEND" },
        "gcp_project_id": { "type": "string", "x-env-var": "SCION_SERVER_SECRETS_GCPPROJECTID" },
        "gcp_credentials": { "type": "string", "x-env-var": "SCION_SERVER_SECRETS_GCPCREDENTIALS" }
      }
    },
    "telemetryConfig": {
      "type": "object",
      "description": "Telemetry and observability configuration.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable telemetry collection.",
          "x-env-var": "SCION_TELEMETRY_ENABLED",
          "x-since": "1"
        },
        "cloud": { "$ref": "#/$defs/telemetryCloud" },
        "hub": { "$ref": "#/$defs/telemetryHub" },
        "local": { "$ref": "#/$defs/telemetryLocal" },
        "filter": { "$ref": "#/$defs/telemetryFilter" },
        "resource": {
          "type": "object",
          "description": "Resource attributes added to all telemetry events (e.g., service.name).",
          "additionalProperties": { "type": "string" },
          "x-since": "1"
        }
      },
      "additionalProperties": false
    },
    "telemetryCloud": {
      "type": "object",
      "description": "Cloud OTLP forwarding settings.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable forwarding telemetry to cloud backend.",
          "x-env-var": "SCION_TELEMETRY_CLOUD_ENABLED",
          "x-since": "1"
        },
        "endpoint": {
          "type": "string",
          "description": "Cloud OTLP endpoint URL.",
          "x-env-var": "SCION_OTEL_ENDPOINT",
          "x-since": "1"
        },
        "protocol": {
          "type": "string",
          "enum": ["grpc", "http"],
          "default": "grpc",
          "description": "OTLP transport protocol.",
          "x-env-var": "SCION_OTEL_PROTOCOL",
          "x-since": "1"
        },
        "headers": {
          "type": "object",
          "description": "Additional headers for OTLP export requests.",
          "additionalProperties": { "type": "string" },
          "x-env-var": "SCION_OTEL_HEADERS",
          "x-since": "1"
        },
        "tls": { "$ref": "#/$defs/telemetryTLS" },
        "batch": { "$ref": "#/$defs/telemetryBatch" }
      },
      "additionalProperties": false
    },
    "telemetryTLS": {
      "type": "object",
      "description": "TLS settings for cloud OTLP export.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable TLS for the OTLP connection.",
          "x-since": "1"
        },
        "insecure_skip_verify": {
          "type": "boolean",
          "default": false,
          "description": "Skip TLS certificate verification.",
          "x-env-var": "SCION_OTEL_INSECURE",
          "x-since": "1"
        },
        "ca_file": {
          "type": "string",
          "description": "Path to a PEM-encoded CA bundle used to verify the OTLP endpoint certificate.",
          "x-env-var": "SCION_OTEL_CA_FILE",
          "x-since": "1"
        }
      },
      "additionalProperties": false
    },
    "telemetryBatch": {
      "type": "object",
      "description": "Batch export settings for OTLP.",
      "properties": {
        "max_size": {
          "type": "integer",
          "default": 512,
          "description": "Maximum number of spans per batch export.",
          "x-since": "1"
        },
        "timeout": {
          "type": "string",
          "default": "5s",
          "description": "Maximum wait time before flushing a partial batch (e.g., '5s').",
          "x-since": "1"
        }
      },
      "additionalProperties": false
    },
    "telemetryHub": {
      "type": "object",
      "description": "Hub telemetry reporting settings.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable reporting telemetry summaries to the Hub. Auto-enabled in hosted mode.",
          "x-env-var": "SCION_TELEMETRY_HUB_ENABLED",
          "x-since": "1"
        },
        "report_interval": {
          "type": "string",
          "default": "30s",
          "description": "Interval between Hub telemetry reports (e.g., '30s').",
          "x-since": "1"
        }
      },
      "additionalProperties": false
    },
    "telemetryLocal": {
      "type": "object",
      "description": "Local debug telemetry output settings.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable local debug telemetry output.",
          "x-env-var": "SCION_TELEMETRY_DEBUG",
          "x-since": "1"
        },
        "file": {
          "type": "string",
          "description": "File path for JSONL telemetry output. If empty, no file output.",
          "x-since": "1"
        },
        "console": {
          "type": "boolean",
          "default": false,
          "description": "Write telemetry debug output to stderr.",
          "x-since": "1"
        }
      },
      "additionalProperties": false
    },
    "telemetryFilter": {
      "type": "object",
      "description": "Event filtering and sampling configuration.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable event filtering.",
          "x-since": "1"
        },
        "respect_debug_mode": {
          "type": "boolean",
          "default": true,
          "description": "Bypass filters when debug mode is active.",
          "x-since": "1"
        },
        "events": { "$ref": "#/$defs/telemetryFilterEvents" },
        "attributes": { "$ref": "#/$defs/telemetryFilterAttributes" },
        "sampling": { "$ref": "#/$defs/telemetrySampling" }
      },
      "additionalProperties": false
    },
    "telemetryFilterEvents": {
      "type": "object",
      "description": "Event type include/exclude lists.",
      "properties": {
        "include": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Event types to include. Empty means all.",
          "x-since": "1"
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Event types to exclude (applied after include).",
          "x-since": "1"
        }
      },
      "additionalProperties": false
    },
    "telemetryFilterAttributes": {
      "type": "object",
      "description": "Attribute redaction and hashing for privacy.",
      "properties": {
        "redact": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Attribute names to redact (replace with placeholder).",
          "x-since": "1"
        },
        "hash": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Attribute names to hash (one-way transform preserving correlation).",
          "x-since": "1"
        }
      },
      "additionalProperties": false
    },
    "telemetrySampling": {
      "type": "object",
      "description": "Sampling rate settings.",
      "properties": {
        "default": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0,
          "description": "Default sampling rate (0.0 to 1.0).",
          "x-since": "1"
        },
        "rates": {
          "type": "object",
          "description": "Per-event-type sampling rates. Keys are event type names.",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "x-since": "1"
        }
      },
      "additionalProperties": false
    },
    "requiredSecret": {
      "type": "object",
      "required": ["key"],
      "properties": {
        "key": { "type": "string", "description": "Secret key name." },
        "description": { "type": "string", "description": "Human-readable description." },
        "type": { "type": "string", "enum": ["environment", "variable", "file"], "default": "environment" },
        "target": { "type": "string", "description": "Projection target (defaults to key for env type)." }
      },
      "additionalProperties": false
    }
  }
}
