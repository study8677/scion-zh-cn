{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scion.dev/schemas/agent/v1.json",
  "title": "Scion Agent Configuration",
  "description": "Configuration for a Scion agent template (scion-agent.yaml).",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema URI for IDE support."
    },
    "schema_version": {
      "type": "string",
      "const": "1",
      "description": "Agent config schema version.",
      "x-since": "1"
    },
    "harness_config": {
      "type": "string",
      "description": "Name of the harness config entry to use (key in harness_configs map). Falls back to 'harness' field for legacy compat."
    },
    "harness": {
      "type": "string",
      "description": "Legacy: harness type name. Deprecated in favor of harness_config.",
      "x-deprecated-by": "1"
    },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "volumes": {
      "type": "array",
      "items": { "$ref": "#/$defs/volumeMount" }
    },
    "resources": { "$ref": "#/$defs/resourceSpec" },
    "max_turns": {
      "type": "integer",
      "minimum": 1,
      "description": "Maximum number of LLM turns before the agent is stopped.",
      "x-since": "1"
    },
    "max_model_calls": {
      "type": "integer",
      "minimum": 1,
      "description": "Maximum number of LLM model API calls before the agent is stopped.",
      "x-since": "1"
    },
    "max_duration": {
      "type": "string",
      "pattern": "^[0-9]+(s|m|h)$",
      "description": "Maximum wall-clock duration before the agent is stopped (e.g., '2h', '30m').",
      "x-since": "1"
    },
    "services": {
      "type": "array",
      "items": { "$ref": "#/$defs/serviceSpec" }
    },
    "mcp_servers": {
      "type": "object",
      "description": "Universal harness-agnostic MCP server configuration. Each key is a server name; the value describes its transport and parameters. The container-side harness provisioner translates these into the harness's native MCP config format.",
      "additionalProperties": { "$ref": "#/$defs/mcpServerConfig" }
    },
    "image": {
      "type": "string",
      "description": "Deprecated: container image override. Move to harness-config config.yaml instead. Retained for backward compatibility as an override.",
      "x-deprecated-by": "1"
    },
    "user": {
      "type": "string",
      "description": "Override unix user."
    },
    "model": {
      "type": "string",
      "description": "Model size alias (small, medium, large) or concrete model name. Prefer size aliases for portability — they are resolved to harness-specific model names at provision time via the harness-config's model_aliases map. Concrete names are passed through unchanged but tie the template to a specific harness."
    },
    "args": {
      "type": "array",
      "items": { "type": "string" }
    },
    "detached": {
      "type": "boolean",
      "description": "Run agent in detached (background) mode. Defaults to true."
    },
    "config_dir": {
      "type": "string",
      "description": "Agent config directory."
    },
    "command_args": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Additional command arguments."
    },
    "task_flag": {
      "type": "string",
      "description": "CLI flag name for passing the task to the harness (e.g., '--input'). When set, the task is delivered as a flag value instead of a positional argument."
    },
    "auth_selectedType": {
      "type": "string",
      "enum": ["api-key", "oauth-token", "auth-file", "vertex-ai"],
      "description": "Deprecated: authentication mechanism override. Move to harness-config config.yaml instead. Retained for backward compatibility as an override.",
      "x-deprecated-by": "1"
    },
    "hub": {
      "type": "object",
      "description": "Hub connection settings override for this agent/template. Takes highest priority over grove and server settings.",
      "properties": {
        "endpoint": {
          "type": "string",
          "format": "uri",
          "description": "Hub API endpoint URL for this agent."
        }
      }
    },
    "telemetry": {
      "$ref": "#/$defs/telemetryConfig",
      "description": "Telemetry settings override for this template/agent. Merged on top of settings-level telemetry config."
    },
    "secrets": {
      "type": "array",
      "items": { "$ref": "#/$defs/requiredSecret" },
      "description": "Required secrets for this agent/template."
    },
    "agent_instructions": {
      "type": "string",
      "description": "Agent instructions for harness-agnostic templates."
    },
    "system_prompt": {
      "type": "string",
      "description": "System prompt for harness-agnostic templates."
    },
    "default_harness_config": {
      "type": "string",
      "description": "Default harness config name for this template."
    },
    "kubernetes": {
      "type": "object",
      "description": "Kubernetes-specific configuration.",
      "properties": {
        "context": { "type": "string" },
        "namespace": { "type": "string" },
        "runtimeClassName": { "type": "string" },
        "serviceAccountName": { "type": "string" },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "limits": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "volumeMount": {
      "type": "object",
      "required": ["target"],
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "read_only": { "type": "boolean", "default": false },
        "type": { "type": "string", "enum": ["local", "gcs"], "default": "local" },
        "bucket": { "type": "string" },
        "prefix": { "type": "string" },
        "mode": { "type": "string" }
      }
    },
    "resourceSpec": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "disk": { "type": "string" }
      }
    },
    "serviceSpec": {
      "type": "object",
      "required": ["name", "command"],
      "properties": {
        "name": { "type": "string" },
        "command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "restart": {
          "type": "string",
          "enum": ["no", "always", "on-failure"]
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Environment variables for the service."
        },
        "ready_check": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["tcp", "http", "delay"]
            },
            "target": { "type": "string" },
            "timeout": { "type": "string" }
          }
        }
      }
    },
    "mcpServerConfig": {
      "type": "object",
      "required": ["transport"],
      "description": "Universal MCP server entry. Field rules: transport=stdio requires command and forbids url/headers; transport=sse|streamable-http requires url and forbids command/args/env.",
      "properties": {
        "transport": {
          "type": "string",
          "enum": ["stdio", "sse", "streamable-http"],
          "description": "MCP transport protocol."
        },
        "command": {
          "type": "string",
          "description": "Executable to launch (stdio only)."
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Command-line arguments (stdio only)."
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Environment variables passed to the MCP process (stdio only). Values support ${VAR_NAME} interpolation."
        },
        "url": {
          "type": "string",
          "description": "Server endpoint URL (sse and streamable-http only). Supports ${VAR_NAME} interpolation."
        },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "HTTP headers (sse and streamable-http only). Values support ${VAR_NAME} interpolation."
        },
        "scope": {
          "type": "string",
          "enum": ["global", "project"],
          "default": "global",
          "description": "Whether to register the server globally for the agent or scoped to its workspace project. Harnesses that do not distinguish project scope (Gemini, OpenCode) treat 'project' as 'global'."
        }
      },
      "additionalProperties": false,
      "oneOf": [
        {
          "properties": {
            "transport": { "const": "stdio" }
          },
          "required": ["command"],
          "not": {
            "anyOf": [
              { "required": ["url"] },
              { "required": ["headers"] }
            ]
          }
        },
        {
          "properties": {
            "transport": { "enum": ["sse", "streamable-http"] }
          },
          "required": ["url"],
          "not": {
            "anyOf": [
              { "required": ["command"] },
              { "required": ["args"] },
              { "required": ["env"] }
            ]
          }
        }
      ]
    },
    "requiredSecret": {
      "type": "object",
      "required": ["key"],
      "properties": {
        "key": { "type": "string", "description": "Secret key name." },
        "description": { "type": "string", "description": "Human-readable description." },
        "type": { "type": "string", "enum": ["environment", "variable", "file"], "default": "environment" },
        "target": { "type": "string", "description": "Projection target (defaults to key for env type)." }
      },
      "additionalProperties": false
    },
    "telemetryConfig": {
      "type": "object",
      "description": "Telemetry and observability configuration override.",
      "properties": {
        "enabled": { "type": "boolean" },
        "cloud": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "endpoint": { "type": "string" },
            "protocol": { "type": "string", "enum": ["grpc", "http"] },
            "headers": { "type": "object", "additionalProperties": { "type": "string" } },
            "tls": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "insecure_skip_verify": { "type": "boolean" },
                "ca_file": { "type": "string" }
              },
              "additionalProperties": false
            },
            "batch": {
              "type": "object",
              "properties": {
                "max_size": { "type": "integer" },
                "timeout": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "hub": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "report_interval": { "type": "string" }
          },
          "additionalProperties": false
        },
        "local": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "file": { "type": "string" },
            "console": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "filter": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "respect_debug_mode": { "type": "boolean" },
            "events": {
              "type": "object",
              "properties": {
                "include": { "type": "array", "items": { "type": "string" } },
                "exclude": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            },
            "attributes": {
              "type": "object",
              "properties": {
                "redact": { "type": "array", "items": { "type": "string" } },
                "hash": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            },
            "sampling": {
              "type": "object",
              "properties": {
                "default": { "type": "number", "minimum": 0, "maximum": 1 },
                "rates": { "type": "object", "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 } }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "resource": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
